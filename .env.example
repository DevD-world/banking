HOST=0.0.0.0
PORT=8000
COMPLETION_IQ_DATA_DIR=/var/data
COMPLETION_IQ_DB_PATH=/var/data/completion_iq.sqlite3
COMPLETION_IQ_UPLOAD_DIR=/var/data/uploads
COMPLETION_IQ_ALLOWED_ORIGIN=*
